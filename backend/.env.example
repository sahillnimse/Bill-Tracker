# SpendWatch Backend - Environment Variables Example
# Copy this file to .env and fill in real values.

CACHE_TTL_SECONDS=900
Z_SCORE_THRESHOLD=2.0
MIN_DOLLAR_DELTA=5
BASELINE_WINDOW_DAYS=14
CORS_ORIGIN=http://localhost:5173

AUTH_FRONTEND_URL=http://localhost:5173
AUTH_SESSION_SECRET=your_super_secret_session_signing_key_32_characters

# ---------- AWS (Cost Explorer) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---------- RunPod ----------
RUNPOD_API_KEY=

# ---------- E2E Networks ----------
E2E_API_KEY=
E2E_PROJECT_ID=
E2E_LOCATION=Delhi

# ---------- Google Ads ----------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# ---------- Microsoft 365 ----------
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_BASIC_LICENSE_COST=170
MS365_STANDARD_LICENSE_COST=830
MS365_PREMIUM_LICENSE_COST=830
